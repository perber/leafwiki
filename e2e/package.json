{
  "name": "leafwiki-e2e",
  "private": true,
  "version": "0.0.0",
  "description": "End-to-end tests for LeafWiki",
  "scripts": {
    "lint": "eslint '{tests,pages}/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint '{tests,pages}/**/*.ts' --fix",
    "format": "prettier \"{tests,pages}/**/*.{ts,tsx,js,jsx}\" --write",
    "format:check": "prettier \"{tests,pages}/**/*.{ts,tsx,js,jsx}\" --check",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "lodash-es": "4.18.1"
  }
}
